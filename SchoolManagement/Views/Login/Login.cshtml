@model SchoolManagement_Ui.Models.Login.LoginModel

@{
    ViewData["Title"] = "Login";
    Layout = null;   // remove layout if using full HTML design
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>

    <link rel="stylesheet" href="@Url.Content("~/login2.css")" />
    <link rel="stylesheet" href="@Url.Content("~/Logincss/boxicons.min.css")" />
   </head>

<body>

    <div id="toast-container"></div>

    <div class="bg"></div>
    <div class="bg bg2"></div>
    <div class="bg bg3"></div>
    <div class="content">
        <h1>Sliding Diagonals Background Effect</h1>
    </div>
    <div class="container">

        <!-- LOGIN FORM -->
        <div class="form-box login">
            <form asp-action="Login" method="post">

                <h1>Login</h1>

                <div class="input-box">
                    <input asp-for="Email" placeholder="Email" required />
                    <i class='bx bxs-user'></i>
                </div>
                <span asp-validation-for="Email" class="text-danger"></span>

                <div class="input-box">
                    <input asp-for="Password" type="password" placeholder="Password" required />
                    <i class='bx bxs-lock-alt'></i>
                </div>
                <span asp-validation-for="Password" class="text-danger"></span>

                <div class="forgot-link">
                    <a href="#">Forgot password</a>
                </div>

                <button type="submit" class="btn" id="loginBtn">
                    Login
                </button>
                @if (TempData["ErrorMessage"] != null)
                {
                    <script>
                        window.onload = function () {
                            showToast("@TempData["ErrorMessage"]");
                        };
                    </script>
                }

            </form>
        </div>


        <!-- FORGOT PASSWORD FORM -->
        <div class="form-box register">
            <form asp-action="Forgot" method="post">

                <h1>Forgot Password</h1>

                <div class="input-box">
                    <input type="email" name="Email" placeholder="Email" required />
                    <i class='bx bxs-envelope'></i>
                </div>
                <button type="submit" class="btn">Forgot</button>

            </form>
        </div>


        <!-- TOGGLE PANEL -->
        <div class="toggle-box">
            <div class="toggle-panel toggle-left">
                <img src="@Url.Content("~/images/hollycrosslogo.png")" width="100" height="100" />
                <br />
                <h1>Hello, Welcome!</h1>
                <p>Don't have an account?</p>
                <button class="btn register-btn" type="button">Forgot Password</button>
            </div>

            <div class="toggle-panel toggle-right">
                <h1>Welcome Back!</h1>
                <p>Already have an account?</p>
                <button class="btn login-btn" type="button">Login</button>
            </div>
        </div>

    </div>
    
    
</body>
</html>
<script src="~/java.js" defer></script>
<script>
    document.querySelector("form").addEventListener("submit", function () {

        var btn = document.getElementById("loginBtn");

        btn.innerText = "Logging in...";
        btn.disabled = true;

    });

             function showToast(message){

        const container = document.getElementById("toast-container");

        const toast = document.createElement("div");
        toast.className = "toast";
        toast.innerText = message;

        container.appendChild(toast);

        setTimeout(() => {
            toast.classList.add("show");
        },100);

        setTimeout(() => {
            toast.classList.remove("show");

            setTimeout(()=>{
                toast.remove();
            },400);

        },5000);
    }
</script>