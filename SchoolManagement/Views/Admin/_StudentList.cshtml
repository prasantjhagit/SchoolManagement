@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Student List";
}

<style>

    body {
        background: #f4f6f9;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
    }

    .page-title {
        font-size: 20px;
        font-weight: 600;
        color: #2c3e50;
    }

    .card-ui {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.06);
        padding: 15px;
        margin-bottom: 15px;
    }

    .student-table {
        font-size: 13px;
        border-radius: 10px;
        overflow: hidden;
    }

        .student-table th {
            background: #f8f9fa;
            white-space: nowrap;
            font-weight: 600;
        }

    .filter-bar .form-control,
    .filter-bar .form-select {
        height: 38px;
        font-size: 13px;
        border-radius: 8px;
    }

    .btn-modern {
        border-radius: 8px;
        padding: 6px 12px;
    }

    .btn-success {
        background: linear-gradient(45deg,#28a745,#218838);
        border: none;
    }

    .action-btn {
        padding: 4px 8px;
        border-radius: 6px;
    }

    .table-hover tbody tr:hover {
        background: #f1f7f3;
    }

    .pagination .page-link {
        border-radius: 6px;
        margin: 0 2px;
    }

</style>

<div class="container-fluid">

    <!-- HEADER -->
    <div class="page-header">
        <div class="page-title">
            <i class="fa fa-users text-success"></i> Student List
        </div>
    </div>

    <!-- FILTER CARD -->
    <div class="card-ui">
        <div class="row filter-bar g-2">

            <div class="col-lg-3 col-md-6">
                <input id="searchInput" type="text" class="form-control"
                       placeholder="🔍 Search Name / Roll / Reg / Phone">
            </div>

            <div class="col-lg-2 col-md-3">
                <select id="classDropdown" class="form-select">
                    <option value="">Class</option>
                    <option value="1">1</option>
                    <option value="2">2</option>
                    <option value="3">3</option>
                    <option value="4">4</option>
                    <option value="5">5</option>
                    <option value="6">6</option>
                    <option value="7">7</option>
                    <option value="8">8</option>
                    <option value="9">9</option>
                    <option value="10">10</option>
                </select>
            </div>

            <div class="col-lg-2 col-md-3">
                <select id="sectionDropdown" class="form-select">
                    <option value="">Section</option>
                    <option value="A">A</option>
                    <option value="B">B</option>
                </select>
            </div>

            <div class="col-lg-2 col-md-3">
                <select id="sessionDropdown" class="form-select">
                    <option value="">Session</option>
                    <option value="2026">2026</option>
                    <option value="2025">2025</option>
                    <option value="2024">2024</option>
                </select>
            </div>

            <div class="col-lg-2 col-md-3">
                <button id="exportExcelBtn" class="btn btn-success btn-modern w-100">
                    <i class="fa fa-download"></i> Export
                </button>
            </div>

        </div>
    </div>

    <!-- TABLE CARD -->
    <div class="card-ui">

        <div class="table-responsive">
            <table class="table table-hover table-bordered student-table mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Roll</th>
                        <th>RegNo</th>
                        <th>Class</th>
                        <th>Section</th>
                        <th>Session</th>
                        <th>Phone</th>
                        <th>Admission</th>
                        <th>Admitted By</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody id="studentTableBody"></tbody>
            </table>
        </div>

        <!-- PAGINATION -->
        <div class="d-flex justify-content-between align-items-center mt-3">

            <div id="paginationInfo" style="font-size:13px;">
                Showing 0 to 0 of 0 entries
            </div>

            <nav>
                <ul id="paginationContainer" class="pagination pagination-sm mb-0"></ul>
            </nav>

        </div>

    </div>

</div>

<!-- ================= JS (UNCHANGED LOGIC) ================= -->

<script>
    let allStudents = [];
    let currentPage = 1;
    const pageSize = 10;

    function formatDate(dateString){
        if(!dateString) return "";
        let parts = dateString.split("T")[0].split("-");
        return `${parts[2]}-${parts[1]}-${parts[0]}`;
    }

    function renderTable(data){
        let tbody = document.getElementById("studentTableBody");
        tbody.innerHTML = "";

        if(!data || data.length === 0){
            tbody.innerHTML = `<tr><td colspan="11" class="text-center">No records found</td></tr>`;
            return;
        }

        data.forEach(student => {
            let row = `<tr>
                <td>${student.studentName ?? ""}</td>
                <td>${student.rollNumber ?? ""}</td>
                <td>${student.registrationNumber ?? ""}</td>
                <td>${student.class ?? ""}</td>
                <td>${student.section ?? ""}</td>
                <td>${student.session ?? ""}</td>
                <td>${student.parentPhone ?? ""}</td>
                <td>${formatDate(student.admissionDate)}</td>
                <td>${student.fatherName ?? ""}</td>
                <td><span class="badge bg-success">Active</span></td>
                <td>
                    <button class="btn btn-sm action-btn" onclick="editStudent(${student.studentId})">
                        <i class="fas fa-edit"></i>
                    </button>
                    <button class="btn btn-sm action-btn">
                        <i class="fa fa-trash text-danger"></i>
                    </button>
                </td>
            </tr>`;
            tbody.innerHTML += row;
        });
    }

    function updatePagination(){
        const paginationContainer = document.getElementById("paginationContainer");
        const paginationInfo = document.getElementById("paginationInfo");

        paginationContainer.innerHTML = "";

        const totalRecords = allStudents.length;
        const totalPages = Math.ceil(totalRecords / pageSize);

        if(totalRecords === 0){
            paginationInfo.innerText = "Showing 0 to 0 of 0 entries";
            return;
        }

        const startIndex = (currentPage - 1) * pageSize;
        const endIndex = Math.min(startIndex + pageSize, totalRecords);

        paginationInfo.innerText = `Showing ${startIndex + 1} to ${endIndex} of ${totalRecords} entries`;

        paginationContainer.innerHTML += `
            <li class="page-item ${currentPage === 1 ? "disabled" : ""}">
                <a class="page-link" href="javascript:void(0)" onclick="changePage(${currentPage - 1})">Previous</a>
            </li>`;

        for(let i = 1; i <= totalPages; i++){
            paginationContainer.innerHTML += `
                <li class="page-item ${currentPage === i ? "active" : ""}">
                    <a class="page-link" href="javascript:void(0)" onclick="changePage(${i})">${i}</a>
                </li>`;
        }

        paginationContainer.innerHTML += `
            <li class="page-item ${currentPage === totalPages ? "disabled" : ""}">
                <a class="page-link" href="javascript:void(0)" onclick="changePage(${currentPage + 1})">Next</a>
            </li>`;
    }

    function bindPagedData(){
        const startIndex = (currentPage - 1) * pageSize;
        const endIndex = startIndex + pageSize;
        const pagedData = allStudents.slice(startIndex, endIndex);

        renderTable(pagedData);
        updatePagination();
    }

    function changePage(page){
        const totalPages = Math.ceil(allStudents.length / pageSize);
        if(page < 1 || page > totalPages) return;

        currentPage = page;
        bindPagedData();
    }

    function loadStudents(search="", classFilter="", sectionFilter="", sessionFilter=""){
        const url = `/Admin/FilterStudentList?search=${encodeURIComponent(search)}&classFilter=${encodeURIComponent(classFilter)}&sectionFilter=${encodeURIComponent(sectionFilter)}&sessionFilter=${encodeURIComponent(sessionFilter)}`;

        fetch(url)
            .then(res => res.json())
            .then(data => {
                allStudents = data || [];
                currentPage = 1;
                bindPagedData();
            });
    }

    document.addEventListener("DOMContentLoaded", function(){

        const searchInput = document.getElementById("searchInput");
        const classDropdown = document.getElementById("classDropdown");
        const sectionDropdown = document.getElementById("sectionDropdown");
        const sessionDropdown = document.getElementById("sessionDropdown");

        function getFilters(){
            return {
                search: searchInput.value,
                classFilter: classDropdown.value,
                sectionFilter: sectionDropdown.value,
                sessionFilter: sessionDropdown.value
            };
        }

        loadStudents();

        searchInput.addEventListener("keyup", () => loadStudents(...Object.values(getFilters())));
        classDropdown.addEventListener("change", () => loadStudents(...Object.values(getFilters())));
        sectionDropdown.addEventListener("change", () => loadStudents(...Object.values(getFilters())));
        sessionDropdown.addEventListener("change", () => loadStudents(...Object.values(getFilters())));

    });

    function editStudent(studentId){
        window.location.href = `/Admin/Admission?studentId=${studentId}`;
    }
</script>