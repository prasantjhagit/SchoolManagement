@using SchoolManagement_Ui.DTO
@model List<TodayStudentStatusDto>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Student Attendance Dashboard";
}

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    .dashboard-card {
        background: white;
        border-radius: 14px;
        padding: 25px;
        box-shadow: 0 5px 25px rgba(0,0,0,0.08);
    }

    .summary-card {
        border-radius: 12px;
        padding: 20px;
        color: white;
        display: flex;
        justify-content: space-between;
    }

    .total {
        background: linear-gradient(45deg,#36d1dc,#5b86e5);
    }

    .present {
        background: linear-gradient(45deg,#00b09b,#96c93d);
    }

    .absent {
        background: linear-gradient(45deg,#ff416c,#ff4b2b);
    }

    .late {
        background: linear-gradient(45deg,#f7971e,#ffd200);
    }

    .filter-box {
        background: #f8f9fc;
        padding: 18px;
        border-radius: 10px;
        margin-top: 25px;
    }

    .student-img {
        width: 35px;
        height: 35px;
        border-radius: 50%;
    }

    .badge-present {
        background: #e8fff3;
        color: #00a65a;
        padding: 6px 12px;
        border-radius: 20px;
    }

    .badge-absent {
        background: #ffeaea;
        color: #e74c3c;
        padding: 6px 12px;
        border-radius: 20px;
    }

    .badge-late {
        background: #fff3cd;
        color: #856404;
        padding: 6px 12px;
        border-radius: 20px;
    }
</style>

<div class="container-fluid">
    <div class="dashboard-card">

        <h4 class="mb-4">Student Attendance Dashboard</h4>

        <!-- SUMMARY -->
        <div class="row g-3">
            <div class="col-md-3"><div class="summary-card total"><div><small>Total</small><h3 id="totalCount">@Model.Count()</h3></div></div></div>
            <div class="col-md-3"><div class="summary-card present"><div><small>Present</small><h3 id="presentCount">@Model.Count(x => x.TodayStatus == "Present")</h3></div></div></div>
            <div class="col-md-3"><div class="summary-card absent"><div><small>Absent</small><h3 id="absentCount">@Model.Count(x => x.TodayStatus == "Absent")</h3></div></div></div>
            <div class="col-md-3"><div class="summary-card late"><div><small>Late</small><h3 id="lateCount">@Model.Count(x => x.TodayStatus == "Late")</h3></div></div></div>
        </div>

        <!-- FILTER -->
        <div class="filter-box">
            <div class="row g-3">

                <div class="col-md-3">
                    <input type="text" id="searchBox" class="form-control" placeholder="Search">
                </div>

                <div class="col-md-2">
                    <select id="classFilter" class="form-control">
                        <option value="All">All</option>
                        <option value="Class 1">Class 1</option>
                        <option value="Class 2">Class 2</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <select id="sectionFilter" class="form-control">
                        <option value="All">All</option>
                        <option value="A">A</option>
                        <option value="B">B</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <input type="date" id="dateFilter" class="form-control">
                </div>

                <div class="col-md-2">
                    <button id="exportExcelBtn" class="btn btn-success w-100">Export</button>
                </div>

            </div>
        </div>

        <!-- TABLE -->
        <div class="table-responsive mt-3">
            <table id="studentTable" class="table table-hover">
                <thead>
                    <tr>
                        <th>Roll</th>
                        <th>Name</th>
                        <th>Present</th>
                        <th>Absent</th>
                        <th>Late</th>
                        <th>Status</th>
                    </tr>
                </thead>

                <tbody id="studentTableBody">
                    @foreach (var s in Model)
                    {
                        <tr>
                            <td>@s.RollNumber</td>
                            <td>@s.StudentName</td>
                            <td>@s.PresentCount</td>
                            <td>@s.AbsentCount</td>
                            <td>@s.LateCount</td>
                            <td>@s.TodayStatus</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
    let timer;

    function loadData() {
        $.get('/Admin/FilterStudentAttendance', {
            search: $('#searchBox').val(),
            studentClass: $('#classFilter').val(),
            section: $('#sectionFilter').val(),
            date: $('#dateFilter').val()
        }, function (data) {

            let rows = '';
            let present=0, absent=0, late=0;

            data.forEach(s => {

                if(s.todayStatus==="Present") present++;
                else if(s.todayStatus==="Absent") absent++;
                else late++;

                rows += `<tr>
                    <td>${s.rollNumber}</td>
                    <td>${s.studentName}</td>
                    <td>${s.presentCount}</td>
                    <td>${s.absentCount}</td>
                    <td>${s.lateCount}</td>
                    <td>${s.todayStatus}</td>
                </tr>`;
            });

            $('#studentTableBody').html(rows);

            $('#totalCount').text(data.length);
            $('#presentCount').text(present);
            $('#absentCount').text(absent);
            $('#lateCount').text(late);
        });
    }

    $(document).on('keyup', '#searchBox', function () {
        clearTimeout(timer);
        timer = setTimeout(loadData, 400);
    });

    $(document).on('change', '#classFilter, #sectionFilter, #dateFilter', loadData);

</script>

<script>
    function exportTableToExcel(filename="Students.csv") {

        const table = document.getElementById("studentTable");

        if (!table) {
            alert("Table not found!");
            return;
        }

        let csv=[];
        table.querySelectorAll("tr").forEach(row=>{
            let cols=[];
            row.querySelectorAll("th,td").forEach(cell=>{
                cols.push(`"${cell.innerText}"`);
            });
            csv.push(cols.join(","));
        });

        const blob=new Blob([csv.join("\n")],{type:"text/csv"});
        const link=document.createElement("a");
        link.href=URL.createObjectURL(blob);
        link.download=filename;
        link.click();
    }

    $(document).on('click','#exportExcelBtn',function(){
        exportTableToExcel();
    });
</script>