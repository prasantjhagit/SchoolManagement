@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "New Student Admission";
}

<style>
    body {
        background: #f4f6f9;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .page-title {
        font-size: 22px;
        font-weight: 600;
        color: #2c3e50;
    }

    .admission-card {
        background: #fff;
        border-radius: 15px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        padding: 25px;
        margin-bottom: 20px;
        border-left: 5px solid #28a745;
    }

    .section-title {
        font-size: 15px;
        font-weight: 600;
        margin-bottom: 15px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .form-control, .form-select {
        border-radius: 8px;
        padding: 10px;
    }

    .sticky-actions {
        position: sticky;
        bottom: 0;
        background: #fff;
        padding: 15px;
        border-top: 1px solid #eee;
        text-align: right;
    }

    .validation-error {
        color: red;
        font-size: 12px;
    }

    .input-error {
        border-color: red !important;
    }

    #photoPreview {
        width: 100px;
        margin-top: 10px;
        display: none;
        border-radius: 10px;
    }
</style>

<div class="page-header">
    <div class="page-title">
        <i class="fa fa-user-plus text-success"></i> New Student Admission
    </div>
</div>

<form id="admissionForm" enctype="multipart/form-data">
    <input type="hidden" id="StudentId" name="StudentId" value="0" />

    <!-- STUDENT INFO -->
    <div class="admission-card">
        <div class="section-title"><i class="fa fa-user"></i> Student Information</div>

        <div class="row g-3">

            <div class="col-md-3">
                <input type="text" id="schoolCode" name="SchoolCode" class="form-control" placeholder="School Code" />
                <label class="validation-error" id="schoolCodeError"></label>
            </div>

            <div class="col-md-3">
                <select id="classSelect" name="Class" class="form-select">
                    <option value="">Select Class</option>
                    <option value="01">1</option>
                    <option value="02">2</option>
                    <option value="03">3</option>
                    <option value="04">4</option>
                    <option value="05">5</option>
                    <option value="06">6</option>
                    <option value="07">7</option>
                    <option value="08">8</option>
                    <option value="09">9</option>
                    <option value="10">10</option>
                </select>
                <label class="validation-error" id="classSelectError"></label>
            </div>

            <div class="col-md-3">
                <select id="sessionSelect" name="Session" class="form-select">
                    <option value="">Select Session</option>
                    <option value="2026">2026</option>
                    <option value="2025">2025</option>
                    <option value="2024">2024</option>
                </select>
                <label class="validation-error" id="sessionSelectError"></label>
            </div>

            <div class="col-md-3">
                <input type="text" id="registrationNumber" name="RegistrationNumber" class="form-control" placeholder="Registration Number" />
            </div>

            <div class="col-md-4">
                <input type="text" id="StudentName" name="StudentName" class="form-control" placeholder="Student Name" />
                <label class="validation-error" id="StudentNameError"></label>
            </div>

            <div class="col-md-4">
                <input type="date" name="AdmissionDate" class="form-control" />
            </div>

            <div class="col-md-4">
                <input type="text" name="RollNumber" class="form-control" placeholder="Roll Number" />
            </div>

            <div class="col-md-3">
                <select name="Section" class="form-select">
                    <option>Select Section</option>
                    <option>A</option>
                    <option>B</option>
                    <option>C</option>
                </select>
            </div>

        </div>
    </div>

    <!-- PARENTS -->
    <div class="admission-card">
        <div class="section-title"><i class="fa fa-users"></i> Parents Information</div>

        <div class="row g-3">
            <div class="col-md-4"><input type="text" name="FatherName" class="form-control" placeholder="Father Name" /></div>
            <div class="col-md-4"><input type="text" name="MotherName" class="form-control" placeholder="Mother Name" /></div>
            <div class="col-md-4"><input type="text" name="ParentPhone" class="form-control" placeholder="Parent Phone" /></div>
        </div>
    </div>

    <!-- STUDENT DETAILS -->
    <div class="admission-card">
        <div class="section-title"><i class="fa fa-id-card"></i> Student Details</div>

        <div class="row g-3">

            <div class="col-md-3">
                <input type="date" name="DateOfBirth" class="form-control" />
            </div>

            <div class="col-md-3">
                <select name="Gender" class="form-select">
                    <option>Gender</option>
                    <option>Male</option>
                    <option>Female</option>
                    <option>Other</option>
                </select>
            </div>

            <div class="col-md-3">
                <input type="email" name="Email" class="form-control" placeholder="Email" />
            </div>

            <div class="col-md-3">
                <input type="file" name="studentPhoto" class="form-control" onchange="previewPhoto(event)" />
                <img id="photoPreview" />
            </div>

        </div>
    </div>

    <!-- ADDRESS -->
    <div class="admission-card">
        <div class="section-title"><i class="fa fa-map-marker-alt"></i> Address</div>

        <div class="row g-3">

            <div class="col-md-3">
                <input type="text" id="pincode" name="Pincode" class="form-control" placeholder="Enter PIN Code" />
            </div>

            <div class="col-md-3">
                <input type="text" id="town" name="Town" class="form-control" placeholder="Town / Area" />
            </div>

            <div class="col-md-3">
                <input type="text" id="city" name="City" class="form-control" placeholder="City" />
            </div>

            <div class="col-md-3">
                <input type="text" id="state" name="State" class="form-control" placeholder="State" />
            </div>

        </div>

        <div class="mt-3">
<textarea id="address" name="FullAddress" class="form-control" rows="2" placeholder="Address"></textarea>
        </div>

    </div>

    <!-- DOCUMENT -->
    <div class="admission-card">
        <div class="section-title"><i class="fa fa-file-upload"></i> Address Proof Upload</div>

        <div class="row g-3">

            <div class="col-md-4">
                <select name="Documents[0].DocumentType" class="form-select">
                    <option>Select Address Proof Type</option>
                    <option>Aadhar Card</option>
                    <option>Passport</option>
                    <option>Electricity Bill</option>
                    <option>Ration Card</option>
                    <option>Driving License</option>
                </select>
            </div>

            <div class="col-md-4">
                <input type="file" name="documentFiles" class="form-control" />
            </div>

            <div class="col-md-4">
                <input type="text" name="Documents[0].DocumentNumber" class="form-control" placeholder="Document Number" />
            </div>

        </div>
    </div>

    <!-- BUTTON -->
    <div class="sticky-actions">
        <button type="submit" id="saveBtn" class="btn btn-success">
            <i class="fa fa-save"></i> Save
        </button>

        <button type="reset" class="btn btn-secondary">
            Reset
        </button>
    </div>

</form>

<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

<script>

    toastr.options = { positionClass: "toast-top-right" };

    function previewPhoto(e){
        const img=document.getElementById("photoPreview");
        img.src=URL.createObjectURL(e.target.files[0]);
        img.style.display="block";
    }

    function validateForm(){
        let valid=true;

        if(!schoolCode.value){
            schoolCodeError.innerText="Required"; valid=false;
        }
        if(!StudentName.value){
            StudentNameError.innerText="Required"; valid=false;
        }
        if(!classSelect.value){
            classSelectError.innerText="Required"; valid=false;
        }
        if(!sessionSelect.value){
            sessionSelectError.innerText="Required"; valid=false;
        }

        return valid;
    }

    document.getElementById("admissionForm").addEventListener("submit", async function(e){

        e.preventDefault();
        if(!validateForm()) return;

        const formData=new FormData(this);
        const btn=document.getElementById("saveBtn");

        btn.disabled=true;
        btn.innerHTML="Saving...";

        try{
            const res=await fetch('/Admin/SaveAdmission',{method:'POST',body:formData});
            const result=await res.json();

            if(result.success){
                toastr.success("Saved Successfully");
                this.reset();
                photoPreview.style.display="none";
            }else{
                toastr.error(result.message);
            }

        }catch{
            toastr.error("Server Error");
        }

        btn.disabled=false;
        btn.innerHTML="Save";
    });

</script>