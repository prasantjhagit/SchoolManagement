@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "New Student Admission";
}
<!-- ✅ jQuery FIRST -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>

<!-- ✅ Toastr CSS -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />

<!-- ✅ Toastr JS -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
<style>
    body {
        background: #f4f6f9;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .page-title {
        font-size: 22px;
        font-weight: 600;
        color: #2c3e50;
    }

    .admission-card {
        background: #fff;
        border-radius: 15px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        padding: 25px;
        margin-bottom: 20px;
        border-left: 5px solid #28a745;
    }

    .section-title {
        font-size: 15px;
        font-weight: 600;
        margin-bottom: 15px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .form-control, .form-select {
        border-radius: 8px;
        padding: 10px;
    }

    .sticky-actions {
        position: sticky;
        bottom: 0;
        background: #fff;
        padding: 15px;
        border-top: 1px solid #eee;
        text-align: right;
    }

    .validation-error {
        color: red;
        font-size: 12px;
    }

    .input-error {
        border-color: red !important;
    }

    #photoPreview {
        width: 100px;
        margin-top: 10px;
        display: none;
        border-radius: 10px;
    }

    .admission-card {
        overflow: visible !important;
    }
</style>

<div class="page-header">
    <div class="page-title">
        <i class="fa fa-user-plus text-success"></i> New Student Admission
    </div>
</div>

<form id="admissionForm" enctype="multipart/form-data">
    <input type="hidden" id="StudentId" name="StudentId" value="0" />

    <!-- STUDENT INFO -->
    <div class="admission-card">
        <div class="section-title"><i class="fa fa-user"></i> Student Information</div>

        <div class="row g-3">

            <div class="col-md-3">
                <input type="text" id="schoolCode" name="SchoolCode" class="form-control" placeholder="School Code" />
                <label class="validation-error" id="schoolCodeError"></label>
            </div>

            <div class="col-md-3">
                <select id="classSelect" name="Class" class="form-select">
                    <option value="">Select Class</option>
                    <option value="01">1</option>
                    <option value="02">2</option>
                    <option value="03">3</option>
                    <option value="04">4</option>
                    <option value="05">5</option>
                    <option value="06">6</option>
                    <option value="07">7</option>
                    <option value="08">8</option>
                    <option value="09">9</option>
                    <option value="10">10</option>
                </select>
                <label class="validation-error" id="classSelectError"></label>
            </div>

            <div class="col-md-3">
                <select id="sessionSelect" name="Session" class="form-select">
                    <option value="">Select Session</option>
                    <option value="2026">2026</option>
                    <option value="2025">2025</option>
                    <option value="2024">2024</option>
                </select>
                <label class="validation-error" id="sessionSelectError"></label>
            </div>

            <div class="col-md-3">
                <input type="text" id="registrationNumber" name="RegistrationNumber" class="form-control" placeholder="Registration Number" />
            </div>

            <div class="col-md-4">
                <input type="text" id="StudentName" name="StudentName" class="form-control" placeholder="Student Name" />
                <label class="validation-error" id="StudentNameError"></label>
            </div>

            <div class="col-md-4">
                <input type="date" name="AdmissionDate" class="form-control" />
            </div>

            <div class="col-md-4">
                <input type="text" name="RollNumber" class="form-control" placeholder="Roll Number" />
            </div>

            <div class="col-md-3">
                <select name="Section" class="form-select">
                    <option>Select Section</option>
                    <option>A</option>
                    <option>B</option>
                    <option>C</option>
                </select>
            </div>

        </div>
    </div>

    <!-- PARENTS -->
    <div class="admission-card">
        <div class="section-title"><i class="fa fa-users"></i> Parents Information</div>

        <div class="row g-3">
            <div class="col-md-4"><input type="text" name="FatherName" class="form-control" placeholder="Father Name" /></div>
            <div class="col-md-4"><input type="text" name="MotherName" class="form-control" placeholder="Mother Name" /></div>
            <div class="col-md-4"><input type="text" name="ParentPhone" class="form-control" placeholder="Parent Phone" /></div>
        </div>
    </div>

    <!-- STUDENT DETAILS -->
    <div class="admission-card">
        <div class="section-title"><i class="fa fa-id-card"></i> Student Details</div>

        <div class="row g-3 align-items-center">

            <!-- DOB -->
            <div class="col-md-2">
                <input type="date" name="DateOfBirth" class="form-control" />
            </div>

            <!-- GENDER -->
            <div class="col-md-2">
                <select name="Gender" class="form-select">
                    <option>Gender</option>
                    <option>Male</option>
                    <option>Female</option>
                    <option>Other</option>
                </select>
            </div>

            <!-- EMAIL -->
            <div class="col-md-3">
                <input type="email" name="Email" class="form-control" placeholder="Email" />
            </div>

            <div class="col-md-5">

                <input type="file" id="studentPhotoInput" name="studentPhoto"
                       class="form-control mb-2"
                       accept="image/*"
                       onchange="handlePhotoPreview(event)" />

                <!-- THUMB -->
                <div id="photoPreviewWrapper"
                     style="display:none; position:relative; width:80px;">

                    <img id="photoPreview"
                         style="width:80px; height:80px;
                    display:block;
                    object-fit:cover;
                    border:2px solid #28a745;
                    border-radius:8px;" />

                    <!-- ❌ -->
                    <span onclick="removePhoto()"
                          style="position:absolute; top:-8px; right:-8px;
                     background:red; color:white;
                     width:20px; height:20px;
                     border-radius:50%;
                     display:flex;
                     align-items:center;
                     justify-content:center;
                     cursor:pointer;">
                        ×
                    </span>

                </div>

            </div>

        </div>
    </div>

    <!-- ADDRESS -->
    <div class="admission-card">
        <div class="section-title"><i class="fa fa-map-marker-alt"></i> Address</div>

        <div class="row g-3">

            <div class="col-md-3">
                <input type="text" id="pincode" name="Pincode" class="form-control" placeholder="Enter PIN Code" />
            </div>

            <div class="col-md-3">
                <input type="text" id="town" name="Town" class="form-control" placeholder="Town / Area" />
            </div>

            <div class="col-md-3">
                <input type="text" id="city" name="City" class="form-control" placeholder="City" />
            </div>

            <div class="col-md-3">
                <input type="text" id="state" name="State" class="form-control" placeholder="State" />
            </div>

        </div>

        <div class="mt-3">
<textarea id="address" name="FullAddress" class="form-control" rows="2" placeholder="Address"></textarea>
        </div>

    </div>

    <!-- DOCUMENT -->
    <div class="admission-card">
        <div class="section-title"><i class="fa fa-file-upload"></i> Address Proof Upload</div>

        <div class="row g-3 align-items-center">

            <div class="col-md-4">
                <select name="Documents[0].DocumentType" class="form-select">
                    <option>Select Address Proof Type</option>
                    <option>Aadhar Card</option>
                    <option>Passport</option>
                    <option>Electricity Bill</option>
                    <option>Ration Card</option>
                    <option>Driving License</option>
                </select>
            </div>

            <div class="col-md-4">
                <input type="file" id="docFile" name="documentFiles" class="form-control"
                       onchange="handleDocPreview(event)" />
            </div>

            <!-- 👁 VIEW BUTTON -->
            <div class="col-md-1">
                <button type="button" id="viewDocBtn" class="btn btn-outline-primary"
                        onclick="openDocPreview()" style="display:none;">
                    <i class="fa fa-eye"></i>
                </button>
            </div>

            <div class="col-md-3">
                <input type="text" name="Documents[0].DocumentNumber" class="form-control" placeholder="Document Number" />
            </div>

        </div>
    </div>

    <!-- BUTTON -->
    <div class="sticky-actions">
        <button type="submit" id="saveBtn" class="btn btn-success">
            <i class="fa fa-save"></i> Save
        </button>

        <button type="reset" class="btn btn-secondary">
            Reset
        </button>
    </div>

</form>

<div class="modal fade" id="docPreviewModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content" style="border-radius:12px; overflow:hidden;">

            <div class="modal-header">
                <h5 class="modal-title">Document Preview</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body" id="docPreviewContainer"
                 style="background:#f8f9fa; min-height:300px; display:flex; align-items:center; justify-content:center;">
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="photoPreviewModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:12px; overflow:hidden;">

            <div class="modal-header">
                <h5 class="modal-title">Photo Preview</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body text-center"
                 style="background:#f8f9fa; min-height:300px; display:flex; align-items:center; justify-content:center;">

                <img id="photoPreviewLarge"
                     style="max-width:100%; max-height:500px; border-radius:10px;" />

            </div>

        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

<script>

    toastr.options = { positionClass: "toast-top-right" };

    function previewPhoto(e){
        const img=document.getElementById("photoPreview");
        img.src=URL.createObjectURL(e.target.files[0]);
        img.style.display="block";
    }

    function validateForm(){
        let valid=true;

        if(!schoolCode.value){
            schoolCodeError.innerText="Required"; valid=false;
        }
        if(!StudentName.value){
            StudentNameError.innerText="Required"; valid=false;
        }
        if(!classSelect.value){
            classSelectError.innerText="Required"; valid=false;
        }
        if(!sessionSelect.value){
            sessionSelectError.innerText="Required"; valid=false;
        }

        return valid;
    }

    document.getElementById("admissionForm").addEventListener("submit", async function(e){

        e.preventDefault();
        if(!validateForm()) return;

        const formData=new FormData(this);
        const btn=document.getElementById("saveBtn");

        btn.disabled=true;
        btn.innerHTML="Saving...";

        try{
            const res=await fetch('/Admin/SaveAdmission',{method:'POST',body:formData});
            const result=await res.json();
            debugger;
    if(result.Success){
        toastr.success("Saved Successfully");

        setTimeout(() => {
            window.location.href = "/Admin/StudentListPartial";
        }, 1500);

    }else{
        toastr.error(result.Message);
    }

        }catch{
            toastr.error("Server Error");
        }

        btn.disabled=false;
        btn.innerHTML="Save";
    });

        let selectedDocFile = null;

    function handleDocPreview(event){
        selectedDocFile = event.target.files[0];

        if(selectedDocFile){
            document.getElementById("viewDocBtn").style.display = "block";
        }
    }

       function openDocPreview(){

        const container = document.getElementById("docPreviewContainer");
        container.innerHTML = "";

        if(!selectedDocFile){
            container.innerHTML = "<p>No file selected</p>";
            return;
        }

        const fileURL = URL.createObjectURL(selectedDocFile);
        const fileType = selectedDocFile.type;
        const fileName = selectedDocFile.name.toLowerCase();

        // IMAGE
        if(fileType.startsWith("image/")){
            container.innerHTML = `
                <div style="text-align:center;">
                    <img src="${fileURL}"
                         style="max-width:100%; max-height:500px; border-radius:10px; box-shadow:0 5px 15px rgba(0,0,0,0.2);" />
                </div>`;
        }

        // PDF
        else if(fileType === "application/pdf"){
            container.innerHTML = `
                <iframe src="${fileURL}"
                        width="100%"
                        height="500px"
                        style="border:none;border-radius:10px;">
                </iframe>`;
        }

        // EXCEL (VIEW IN GOOGLE VIEWER)
        else if(fileName.endsWith(".xls") || fileName.endsWith(".xlsx")){
            container.innerHTML = `
                <iframe
                    src="https://docs.google.com/gview?url=${fileURL}&embedded=true"
                    width="100%"
                    height="500px"
                    style="border:none;">
                </iframe>
                <br/>
                <a href="${fileURL}" target="_blank" class="btn btn-success mt-2">
                    Download Excel
                </a>`;
        }

        // OTHER FILE
        else{
            container.innerHTML = `
                <p>Preview not available</p>
                <a href="${fileURL}" target="_blank" class="btn btn-primary">
                    Download File
                </a>`;
        }

        new bootstrap.Modal(document.getElementById('docPreviewModal')).show();
    }
                  let selectedPhotoFile = null;

    function handlePhotoPreview(event){

        const file = event.target.files[0];

        if(!file){
            console.log("No file selected");
            return;
        }

        // check image type
        if(!file.type.startsWith("image/")){
            alert("Please select an image file");
            return;
        }

        selectedPhotoFile = file;

        const preview = document.getElementById("photoPreview");
        const wrapper = document.getElementById("photoPreviewWrapper");
        document.getElementById("photoPreview").style.border = "5px solid red";

        const imageURL = URL.createObjectURL(file);

        preview.src = imageURL;

        preview.onload = () => {
            URL.revokeObjectURL(imageURL); // memory clean
        };

        wrapper.style.display = "block";
    }

    function removePhoto(){

        selectedPhotoFile = null;

        document.getElementById("studentPhotoInput").value = "";
        document.getElementById("photoPreviewWrapper").style.display = "none";
    }
</script>