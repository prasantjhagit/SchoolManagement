@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<div class="container-fluid">

    <!-- 🔷 PAGE HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-0">Student Transfer</h4>
            <small class="text-muted">Manage student movement & transfer records</small>
        </div>
    </div>

    <!-- 🔷 SEARCH BAR -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">

            <div class="row g-3 align-items-end">

                <div class="col-md-5">
                    <label class="form-label">Search Student</label>
                    <input type="text" class="form-control" placeholder="Enter name or roll number">
                </div>

                <div class="col-md-2">
                    <button class="btn btn-primary w-100">
                        <i class="fa fa-search"></i> Search
                    </button>
                </div>

            </div>

        </div>
    </div>

    <!-- 🔷 STUDENT INFO CARD -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body d-flex justify-content-between align-items-center">

            <div>
                <h5 class="fw-bold mb-1">Rahul Sharma</h5>
                <p class="text-muted mb-0">Roll: 101 | Class: 10 - Section A</p>
            </div>

            <span class="badge bg-success px-3 py-2">Active</span>

        </div>
    </div>

    <!-- 🔷 TRANSFER FORM -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">

            <h6 class="fw-bold mb-3">Transfer Details</h6>

            <div class="row g-3">

                <div class="col-md-3">
                    <label class="form-label">Transfer Type</label>
                    <select class="form-select">
                        <option>Internal Transfer</option>
                        <option>School Transfer (TC)</option>
                        <option>Drop / Leave</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">New Class</label>
                    <select class="form-select">
                        <option>Class 10</option>
                        <option>Class 9</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">New Section</label>
                    <select class="form-select">
                        <option>A</option>
                        <option>B</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Transfer Date</label>
                    <input type="date" class="form-control">
                </div>

                <div class="col-md-12">
                    <label class="form-label">Reason</label>
                    <textarea class="form-control" rows="3" placeholder="Enter transfer reason..."></textarea>
                </div>

                <div class="col-md-12 text-end">
                    <button class="btn btn-danger px-4">
                        <i class="fa fa-right-left"></i> Confirm Transfer
                    </button>
                </div>

            </div>

        </div>
    </div>

    <!-- 🔷 TRANSFER HISTORY -->
    <div class="card shadow-sm border-0">

        <div class="card-body">

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="fw-bold mb-0">Transfer History</h6>
                <button class="btn btn-sm btn-outline-secondary">
                    <i class="fa fa-file-export"></i> Export
                </button>
            </div>

            <div class="table-responsive">

                <table class="table table-hover align-middle text-center">

                    <thead class="table-light">
                        <tr>
                            <th>Date</th>
                            <th>Type</th>
                            <th>From</th>
                            <th>To</th>
                            <th>Reason</th>
                            <th>Status</th>
                        </tr>
                    </thead>

                    <tbody>

                        <tr>
                            <td>01 Jan 2025</td>
                            <td><span class="badge bg-primary">Internal</span></td>
                            <td>10-A</td>
                            <td>10-B</td>
                            <td>Section change</td>
                            <td><span class="badge bg-success">Completed</span></td>
                        </tr>

                        <tr>
                            <td>15 Feb 2025</td>
                            <td><span class="badge bg-danger">TC</span></td>
                            <td>10-B</td>
                            <td>Other School</td>
                            <td>Parent request</td>
                            <td><span class="badge bg-success">Completed</span></td>
                        </tr>

                        <tr>
                            <td>10 Mar 2025</td>
                            <td><span class="badge bg-warning text-dark">Drop</span></td>
                            <td>10-A</td>
                            <td>-</td>
                            <td>Left school</td>
                            <td><span class="badge bg-secondary">Closed</span></td>
                        </tr>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>