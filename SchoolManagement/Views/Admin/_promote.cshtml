@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">

    <!-- 1️⃣ HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold">Promote Students</h4>

        <button class="btn btn-success" id="promoteBtn">
            <i class="fa fa-arrow-up"></i> Promote Selected
        </button>
    </div>

    <!-- 2️⃣ FILTER / SELECTION -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">

            <div class="row g-3">

                <div class="col-md-3">
                    <label class="form-label">Current Class</label>
                    <select class="form-select">
                        <option>Class 10</option>
                        <option>Class 9</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Current Section</label>
                    <select class="form-select">
                        <option>A</option>
                        <option>B</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Promote To Class</label>
                    <select class="form-select">
                        <option>Class 11</option>
                        <option>Class 10</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Promote To Section</label>
                    <select class="form-select">
                        <option>A</option>
                        <option>B</option>
                    </select>
                </div>

            </div>

        </div>
    </div>

    <!-- 3️⃣ STUDENT GRID -->
    <div class="card shadow-sm border-0">

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-hover align-middle text-center">

                    <thead class="table-light">
                        <tr>
                            <th>
                                <input type="checkbox" id="selectAll">
                            </th>
                            <th>Roll No</th>
                            <th class="text-start">Name</th>
                            <th>Class</th>
                            <th>Section</th>
                            <th>Result</th>
                            <th>Status</th>
                        </tr>
                    </thead>

                    <tbody>

                        <tr>
                            <td><input type="checkbox" class="student-check"></td>
                            <td>101</td>
                            <td class="text-start">Rahul Sharma</td>
                            <td>10</td>
                            <td>A</td>
                            <td><span class="badge bg-success">Pass</span></td>
                            <td><span class="badge bg-success">Eligible</span></td>
                        </tr>

                        <tr>
                            <td><input type="checkbox" class="student-check"></td>
                            <td>102</td>
                            <td class="text-start">Anjali Verma</td>
                            <td>10</td>
                            <td>B</td>
                            <td><span class="badge bg-success">Pass</span></td>
                            <td><span class="badge bg-success">Eligible</span></td>
                        </tr>

                        <tr>
                            <td><input type="checkbox" class="student-check"></td>
                            <td>103</td>
                            <td class="text-start">Amit Kumar</td>
                            <td>10</td>
                            <td>A</td>
                            <td><span class="badge bg-danger">Fail</span></td>
                            <td><span class="badge bg-warning text-dark">Not Eligible</span></td>
                        </tr>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

<!-- JS -->
<script>

    // ✅ Select All Checkbox
    document.getElementById("selectAll").addEventListener("change", function () {
        let checkboxes = document.querySelectorAll(".student-check");
        checkboxes.forEach(cb => cb.checked = this.checked);
    });

    // ✅ Promote Button Click
    document.getElementById("promoteBtn").addEventListener("click", function () {

        let selected = document.querySelectorAll(".student-check:checked");

        if (selected.length === 0) {
            alert("Please select at least one student");
            return;
        }

        alert(selected.length + " students promoted successfully!");
    });

</script>