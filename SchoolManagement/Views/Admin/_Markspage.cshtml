@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<div class="container-fluid">

    <!-- 1️⃣ EXAM INFO CARD -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body d-flex justify-content-between align-items-center">

            <div>
                <h5 class="fw-bold mb-1">Mid Term 2025</h5>
                <p class="text-muted mb-0">Class 10 - Section A</p>
            </div>

            <span class="badge bg-primary px-3 py-2">Marks Overview</span>

        </div>
    </div>

    <!-- 2️⃣ FILTER + EXPORT -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">

            <div class="row g-3 align-items-end">

                <div class="col-md-3">
                    <label class="form-label">Exam</label>
                    <select class="form-select">
                        <option>Mid Term 2025</option>
                        <option>Final 2025</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Class</label>
                    <select class="form-select">
                        <option>Class 10</option>
                        <option>Class 9</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Section</label>
                    <select class="form-select">
                        <option>A</option>
                        <option>B</option>
                    </select>
                </div>

                <div class="col-md-3 d-flex gap-2">
                    <button class="btn btn-primary w-50">
                        <i class="fa fa-search"></i> Load
                    </button>

                    <button class="btn btn-success w-50">
                        <i class="fa fa-file-excel"></i> Export
                    </button>
                </div>

            </div>

        </div>
    </div>

    <!-- 3️⃣ GRID -->
    <div class="card shadow-sm border-0">

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-hover align-middle text-center">

                    <thead class="table-light">
                        <tr>
                            <th>Roll No</th>
                            <th class="text-start">Name</th>
                            <th>Class</th>
                            <th>Section</th>
                            <th>Total</th>
                            <th>%</th>
                            <th>Grade</th>
                            <th>Remarks</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody>

                        <tr>
                            <td>101</td>
                            <td class="text-start fw-semibold">Rahul Sharma</td>
                            <td>10</td>
                            <td>A</td>
                            <td class="fw-bold">235</td>
                            <td class="text-primary fw-semibold">78%</td>
                            <td><span class="badge bg-success">A</span></td>
                            <td><span class="badge bg-success">Excellent</span></td>
                            <td>
                                <button class="btn btn-info btn-sm view-btn"
                                        data-name="Rahul Sharma"
                                        data-roll="101"
                                        data-class="10"
                                        data-section="A"
                                        data-math="78"
                                        data-science="82"
                                        data-english="75">
                                    <i class="fa fa-eye"></i> View
                                </button>
                            </td>
                        </tr>

                        <tr>
                            <td>102</td>
                            <td class="text-start fw-semibold">Anjali Verma</td>
                            <td>10</td>
                            <td>B</td>
                            <td class="fw-bold">195</td>
                            <td class="text-primary fw-semibold">65%</td>
                            <td><span class="badge bg-primary">B</span></td>
                            <td><span class="badge bg-info">Good</span></td>
                            <td>
                                <button class="btn btn-info btn-sm view-btn"
                                        data-name="Anjali Verma"
                                        data-roll="102"
                                        data-class="10"
                                        data-section="B"
                                        data-math="65"
                                        data-science="70"
                                        data-english="60">
                                    <i class="fa fa-eye"></i> View
                                </button>
                            </td>
                        </tr>

                        <tr>
                            <td>103</td>
                            <td class="text-start fw-semibold">Amit Kumar</td>
                            <td>10</td>
                            <td>A</td>
                            <td class="fw-bold">123</td>
                            <td class="text-danger fw-semibold">41%</td>
                            <td><span class="badge bg-warning text-dark">C</span></td>
                            <td><span class="badge bg-danger">Needs Improvement</span></td>
                            <td>
                                <button class="btn btn-info btn-sm view-btn"
                                        data-name="Amit Kumar"
                                        data-roll="103"
                                        data-class="10"
                                        data-section="A"
                                        data-math="40"
                                        data-science="38"
                                        data-english="45">
                                    <i class="fa fa-eye"></i> View
                                </button>
                            </td>
                        </tr>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

<!-- 4️⃣ MODAL -->
<div class="modal fade" id="resultModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Student Result Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <h6 id="studentName"></h6>
                <p id="studentInfo" class="text-muted"></p>

                <table class="table table-bordered text-center">
                    <thead class="table-light">
                        <tr>
                            <th>Subject</th>
                            <th>Marks</th>
                        </tr>
                    </thead>

                    <tbody id="subjectMarks"></tbody>
                </table>

                <div class="text-end">
                    <h5>Total: <span id="totalMarks"></span></h5>
                    <h6>Percentage: <span id="percentage"></span></h6>
                </div>

            </div>

        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<!-- JS -->
<script>
    $(document).on("click", ".view-btn", function () {

        let name = $(this).data("name");
        let roll = $(this).data("roll");
        let cls = $(this).data("class");
        let section = $(this).data("section");

        let math = parseInt($(this).data("math"));
        let science = parseInt($(this).data("science"));
        let english = parseInt($(this).data("english"));

        let total = math + science + english;
        let percent = (total / 300 * 100).toFixed(2) + "%";

        $("#studentName").text(name);
        $("#studentInfo").text(`Roll: ${roll} | Class: ${cls}-${section}`);

        $("#subjectMarks").html(`
            <tr><td>Math</td><td>${math}</td></tr>
            <tr><td>Science</td><td>${science}</td></tr>
            <tr><td>English</td><td>${english}</td></tr>
        `);

        $("#totalMarks").text(total);
        $("#percentage").text(percent);

        // ✅ Bootstrap 5 Modal Fix
        var modal = new bootstrap.Modal(document.getElementById('resultModal'));
        modal.show();
    });
</script>