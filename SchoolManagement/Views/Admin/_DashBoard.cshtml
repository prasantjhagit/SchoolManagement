@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<!-- STAT CARDS -->
<div class="row g-4">

    <div class="col-md-3">
        <div class="card shadow-sm border-0 p-3">
            <div class="d-flex justify-content-between">
                <div>
                    <p class="text-muted mb-1">Total Students</p>
                    <h3 class="fw-bold">1,245</h3>
                </div>
                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width:50px;height:50px;">
                    <i class="fa fa-user-graduate"></i>
                </div>
            </div>
            <p class="text-success mt-2 mb-0">+12% this month</p>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-0 p-3">
            <div class="d-flex justify-content-between">
                <div>
                    <p class="text-muted mb-1">Total Teachers</p>
                    <h3 class="fw-bold">86</h3>
                </div>
                <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center" style="width:50px;height:50px;">
                    <i class="fa fa-chalkboard-user"></i>
                </div>
            </div>
            <p class="text-success mt-2 mb-0">+4 new teachers</p>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-0 p-3">
            <div class="d-flex justify-content-between">
                <div>
                    <p class="text-muted mb-1">Total Classes</p>
                    <h3 class="fw-bold">32</h3>
                </div>
                <div class="bg-warning text-white rounded-circle d-flex align-items-center justify-content-center" style="width:50px;height:50px;">
                    <i class="fa fa-school"></i>
                </div>
            </div>
            <p class="text-muted mt-2 mb-0">Active this semester</p>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm border-0 p-3">
            <div class="d-flex justify-content-between">
                <div>
                    <p class="text-muted mb-1">Total Courses</p>
                    <h3 class="fw-bold">54</h3>
                </div>
                <div class="bg-danger text-white rounded-circle d-flex align-items-center justify-content-center" style="width:50px;height:50px;">
                    <i class="fa fa-book"></i>
                </div>
            </div>
            <p class="text-muted mt-2 mb-0">Updated weekly</p>
        </div>
    </div>

</div>


<!-- CHART AREA -->

<div class="row mt-0 g-4">

    <div class="col-md-8">

        <div class="card shadow-sm border-0 p-3">

            <h5 class="mb-3">Student Enrollment Trend</h5>

            <canvas id="enrollmentChart" height="130"></canvas>

        </div>

    </div>


    <div class="col-md-4">

        <div class="card shadow-sm border-0 p-4">

            <h5 class="mb-3">Quick Stats</h5>

            <div class="d-flex justify-content-between mb-2">
                <span>Total Departments</span>
                <strong>12</strong>
            </div>

            <div class="d-flex justify-content-between mb-2">
                <span>Active Courses</span>
                <strong>41</strong>
            </div>

            <div class="d-flex justify-content-between mb-2">
                <span>Pending Approvals</span>
                <strong class="text-danger">6</strong>
            </div>

            <div class="d-flex justify-content-between">
                <span>New Admissions</span>
                <strong class="text-success">23</strong>
            </div>

        </div>

    </div>

</div>



<!-- RECENT ACTIVITY + ANNOUNCEMENTS -->

<div class="row mt-0 g-4">

    <div class="col-md-6">

        <div class="card shadow-sm border-0 p-4">

            <h5 class="mb-3">Recent Activities</h5>

            <ul class="list-group list-group-flush">

                <li class="list-group-item">New student <strong>John Carter</strong> enrolled</li>

                <li class="list-group-item">Teacher <strong>Emma Smith</strong> updated marks</li>

                <li class="list-group-item">Class schedule updated</li>

                <li class="list-group-item">New course <strong>Computer Science</strong> added</li>

                <li class="list-group-item">Exam timetable published</li>

            </ul>

        </div>

    </div>


    <div class="col-md-6">

        <div class="card shadow-sm border-0 p-4">

            <h5 class="mb-3">Announcements</h5>

            <div class="mb-3">
                <strong>Mid Term Exams</strong>
                <p class="text-muted mb-0">Mid term exams will start from next Monday.</p>
            </div>

            <div class="mb-3">
                <strong>New Admission Cycle</strong>
                <p class="text-muted mb-0">Admissions for the next academic year are now open.</p>
            </div>

            <div>
                <strong>Staff Meeting</strong>
                <p class="text-muted mb-0">Meeting scheduled on Friday at 3 PM.</p>
            </div>

        </div>

    </div>

</div>

