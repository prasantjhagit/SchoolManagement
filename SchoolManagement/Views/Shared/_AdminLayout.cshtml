<!DOCTYPE html>
<html>
<head>
    <title>Admin Dashboard</title>

    <!-- CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

    <style>

        body {
            background: #f4f6f9;
            font-family: 'Segoe UI', sans-serif;
        }

        /* 🔷 SIDEBAR */
        .sidebar {
            width: 240px;
            height: 100vh;
            position: fixed;
            background: linear-gradient(180deg, #1e293b, #0f172a);
            color: #fff;
            padding: 20px 10px;
            transition: 0.3s;
        }

            .sidebar.collapsed {
                width: 80px;
            }

            .sidebar h4 {
                text-align: center;
                margin-bottom: 25px;
                font-weight: 600;
            }

            .sidebar a {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 12px;
                margin-bottom: 6px;
                color: #cbd5e1;
                text-decoration: none;
                border-radius: 10px;
                transition: 0.2s;
            }

                .sidebar a:hover {
                    background: rgba(255,255,255,0.08);
                    color: #fff;
                }

            .sidebar i {
                min-width: 20px;
            }

            .sidebar span {
                transition: 0.3s;
            }

            .sidebar.collapsed span {
                display: none;
            }

        /* 🔷 SUBMENU */
        .submenu {
            display: none;
            padding-left: 20px;
        }

        .menu-item.open .submenu {
            display: block;
        }

        /* 🔷 MAIN */
        .main {
            margin-left: 240px;
            transition: 0.3s;
        }

            .main.expanded {
                margin-left: 80px;
            }

        /* 🔷 TOPBAR */
        .topbar {
            background: #fff;
            padding: 15px 20px;
            border-bottom: 1px solid #eee;
        }

        .content {
            padding: 25px;
        }

    </style>
</head>

<body>

    <!-- 🔷 SIDEBAR -->
    <div class="sidebar" id="sidebar">

        <h4>
            <img src="~/images/hollycrosslogo.png" width="40" />
            <span>Dashboard</span>
        </h4>

        <a href="/Admin/DashboardPartial"><i class="fa fa-home"></i> <span>Overview</span></a>

        <!-- ✅ YOUR STUDENT MENU (UNCHANGED) -->
        <div class="menu-item">

            <a href="#" class="menu-toggle">
                <i class="fa fa-user-graduate"></i> <span>Students</span>
            </a>

            <div class="submenu">

                @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
                {
                    <a asp-controller="Admin" asp-action="Admission">
                        <i class="fa fa-user-plus"></i> <span>New Admission</span>
                    </a>

                    <a href="/Admin/StudentListPartial">
                        <i class="fa fa-list"></i> <span>Student List</span>
                    </a>

                    <a href="/Admin/StudentAttendance">
                        <i class="fa fa-calendar-check"></i> <span>Attendance</span>
                    </a>

                    <a href="/Students/Marks">
                        <i class="fa fa-pen"></i> <span>Marks</span>
                    </a>

                    <a href="/Admin/StudentProfile">
                        <i class="fa fa-id-card"></i> <span>Student Profile</span>
                    </a>

                    <a href="/Admin/promote">
                        <i class="fa fa-arrow-up"></i> <span>Promote Students</span>
                    </a>

                    <a href="/Admin/TransferStudent">
                        <i class="fa fa-right-left"></i> <span>Transfer Student</span>
                    </a>
                }

                @if (User.IsInRole("Student"))
                {
                    <a href="/Students/MyProfile">
                        <i class="fa fa-id-card"></i> <span>My Profile</span>
                    </a>

                    <a href="/Students/MyFees">
                        <i class="fa fa-receipt"></i> <span>My Fees</span>
                    </a>
                }

            </div>

        </div>

        <!-- OTHER -->
        @if (User.IsInRole("Admin"))
        {
            <a href="#"><i class="fa fa-chalkboard-user"></i> <span>Teachers</span></a>
        }

        @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
        {
            <a href="#"><i class="fa fa-school"></i> <span>Classes</span></a>
        }

        @if (User.IsInRole("Admin"))
        {
            <a href="/Finance"><i class="fa fa-money-bill"></i> <span>Finance</span></a>
        }

        @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
        {
            <a href="#"><i class="fa fa-chart-line"></i> <span>Reports</span></a>
        }

    </div>

    <!-- 🔷 MAIN -->
    <div class="main" id="main">

        <div class="topbar d-flex justify-content-between align-items-center">

            <div>
                <button id="toggleBtn" class="btn btn-light">
                    <i class="fa fa-bars"></i>
                </button>
                <span class="ms-2 fw-semibold">Admin Panel</span>
            </div>

            <div>
                <i class="fa fa-bell me-3"></i>
                <i class="fa fa-user"></i>
            </div>

        </div>

        <div class="content">
            @RenderBody()
        </div>

    </div>

    <!-- JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Sidebar toggle
        document.getElementById("toggleBtn").addEventListener("click", function () {
            document.getElementById("sidebar").classList.toggle("collapsed");
            document.getElementById("main").classList.toggle("expanded");
        });

        // Submenu toggle
        document.querySelectorAll(".menu-toggle").forEach(menu => {
            menu.addEventListener("click", function (e) {
                e.preventDefault();
                this.parentElement.classList.toggle("open");
            });
        });
    </script>

</body>
</html>