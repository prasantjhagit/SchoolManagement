<!DOCTYPE html>
<html>
<head>
    <title>School Management</title>

    <!-- CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

    <style>
        body {
            margin: 0;
            font-family: 'Segoe UI', sans-serif;
            background: #eef2f7;
        }

        /* 🔵 SIDEBAR */
        .sidebar {
            width: 260px;
            height: 100vh;
            position: fixed;
            background: linear-gradient(180deg, #0a1f44, #0f2a5c);
            color: #fff;
            overflow-y: auto;
            transition: 0.3s;
        }

            .sidebar.collapsed {
                width: 80px;
            }

            .sidebar h4 {
                text-align: center;
                padding: 20px 10px;
                border-bottom: 1px solid rgba(255,255,255,0.1);
            }

            .sidebar a {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 12px 15px;
                color: #cbd5e1;
                text-decoration: none;
                border-radius: 8px;
                margin: 4px 10px;
                transition: 0.2s;
            }

                .sidebar a:hover {
                    background: rgba(255,255,255,0.1);
                    color: #fff;
                }

            .sidebar i {
                min-width: 20px;
            }

            .sidebar span {
                transition: 0.3s;
            }

            .sidebar.collapsed span {
                display: none;
            }

        /* SUBMENU */
        .submenu {
            display: none;
            padding-left: 10px;
        }

        .menu-item.open .submenu {
            display: block;
        }

        .submenu a {
            font-size: 14px;
            padding: 8px 15px;
            color: #94a3b8;
        }

        /* MAIN */
        .main {
            margin-left: 260px;
            transition: 0.3s;
        }

            .main.expanded {
                margin-left: 80px;
            }

        /* TOPBAR */
        .topbar {
            background: #0f2a5c;
            color: #fff;
            padding: 12px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .topbar .btn {
                background: #1e3a8a;
                color: #fff;
                border: none;
            }

                .topbar .btn:hover {
                    background: #2563eb;
                }

        /* CONTENT */
        .content {
            padding: 25px;
        }

        /* CARD */
        .card-custom {
            border: none;
            border-radius: 12px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.08);
        }

    </style>
</head>

