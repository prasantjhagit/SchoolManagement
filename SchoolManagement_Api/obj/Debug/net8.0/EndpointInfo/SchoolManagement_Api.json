{
  "openapi": "3.0.1",
  "info": {
    "title": "School Management API",
    "version": "v1"
  },
  "paths": {
    "/api/AdmissionApi/CreateAdmission": {
      "post": {
        "tags": [
          "AdmissionApi"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AdmissionDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/AdmissionDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/AdmissionDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/AdmissionApi/UploadPhoto": {
      "post": {
        "tags": [
          "AdmissionApi"
        ],
        "parameters": [
          {
            "name": "studentId",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "studentPhoto": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              },
              "encoding": {
                "studentPhoto": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/AdmissionApi/UploadDocuments": {
      "post": {
        "tags": [
          "AdmissionApi"
        ],
        "parameters": [
          {
            "name": "studentId",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "documentFiles": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "format": "binary"
                    }
                  },
                  "documents": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/DocumentDto"
                    }
                  }
                }
              },
              "encoding": {
                "documentFiles": {
                  "style": "form"
                },
                "documents": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/AdmissionApi/GetStudents": {
      "get": {
        "tags": [
          "AdmissionApi"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Login": {
      "post": {
        "tags": [
          "Login"
        ],
        "parameters": [
          {
            "name": "email",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "password",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AdmissionDto": {
        "type": "object",
        "properties": {
          "schoolCode": {
            "type": "string",
            "nullable": true
          },
          "class": {
            "type": "string",
            "nullable": true
          },
          "session": {
            "type": "string",
            "nullable": true
          },
          "registrationNumber": {
            "type": "string",
            "nullable": true
          },
          "rollNumber": {
            "type": "string",
            "nullable": true
          },
          "studentName": {
            "type": "string",
            "nullable": true
          },
          "admissionDate": {
            "type": "string",
            "format": "date-time"
          },
          "section": {
            "type": "string",
            "nullable": true
          },
          "fatherName": {
            "type": "string",
            "nullable": true
          },
          "motherName": {
            "type": "string",
            "nullable": true
          },
          "parentPhone": {
            "type": "string",
            "nullable": true
          },
          "dateOfBirth": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "gender": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "pincode": {
            "type": "string",
            "nullable": true
          },
          "town": {
            "type": "string",
            "nullable": true
          },
          "city": {
            "type": "string",
            "nullable": true
          },
          "state": {
            "type": "string",
            "nullable": true
          },
          "fullAddress": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "DocumentDto": {
        "type": "object",
        "properties": {
          "documentType": {
            "type": "string",
            "nullable": true
          },
          "documentNumber": {
            "type": "string",
            "nullable": true
          },
          "filePath": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "basic": {
        "type": "http",
        "description": "Basic Authentication header",
        "scheme": "basic"
      }
    }
  },
  "security": [
    {
      "basic": [ ]
    }
  ]
}